generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id          Int       @id @default(autoincrement())
  isVerified  Boolean   @default(false)
  email       String    @unique
  phoneNumber String?   @unique
  addresses   Address[]
  cart        Cart?
  orders      Order[]
}

model Asset {
  id        Int       @id @default(autoincrement())
  productId Int
  url       String
  type      AssetType
  altText   String?
  fileId    String    @unique
  reviewId  Int?
  Product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  Review    Review?   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Cart {
  id        Int        @id @default(autoincrement())
  accountId Int        @unique
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  CartItem  CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  createdAt DateTime @default(now())
  size      String?
  quantity  Int      @default(1)
  Cart      Cart     @relation(fields: [cartId], references: [id])
  Product   Product  @relation(fields: [productId], references: [id])
}

model Category {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Product     Product[]
  SubCategory SubCategory[]
}

model Product {
  id            Int         @id @default(autoincrement())
  slug          String      @unique
  title         String
  description   String?
  price         Float
  comparePrice  Float?
  categoryId    Int
  subCategoryId Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  isPublished   Boolean     @default(true)
  inventory     Int         @default(10)
  Asset         Asset[]
  CartItem      CartItem[]
  OrderItems    OrderItem[]
  Category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  SubCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  Review        Review[]
}

model Review {
  id         Int      @id @default(autoincrement())
  productId  Int
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  authorName String
  Asset      Asset[]
  Product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SubCategory {
  id         Int       @id @default(autoincrement())
  categoryId Int
  name       String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Product    Product[]
  Category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Verification {
  id        Int      @id @default(autoincrement())
  email     String
  createdAt DateTime @default(now())
  verified  Boolean  @default(false)
  otp       String
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  title     String
  price     Float
  quantity  Int
  size      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique
  accountId       Int
  email           String
  phoneNumber     String?
  totalAmount     Float
  currency        String        @default("INR")
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  shippingAddress Json
  billingAddress  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  slug            String
  account         Account       @relation(fields: [accountId], references: [id])
  items           OrderItem[]
}

model Address {
  id          Int         @id @default(autoincrement())
  accountId   Int
  fullName    String
  phoneNumber String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String      @default("India")
  type        AddressType @default(SHIPPING)
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

enum AssetType {
  IMAGE
  VIDEO
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AddressType {
  SHIPPING
  BILLING
}
